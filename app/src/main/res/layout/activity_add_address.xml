<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:tools="http://schemas.android.com/tools" xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorCotton"
    tools:ignore="Overdraw">

    <!-- Top Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorCotton"
        android:paddingHorizontal="@dimen/spacing_large"
        android:paddingTop="54dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="1.0"
            app:tint="@color/colorNoirBlack"
            android:contentDescription="@null"/>

        <TextView
            android:id="@+id/tvTitle"
            style="@style/TextAppearance.Saive.SectionHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/address_add_title"
            android:textColor="@color/colorNoirBlack"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="1.0" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Address Label -->
            <TextView
                style="@style/TextAppearance.Saive.Nav"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_address_label"
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp" />

            <LinearLayout
                android:baselineAligned="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_rounded_maroon"
                    android:backgroundTint="@color/colorMaroon"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp"
                    android:text="@string/address_label_home"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chipOffice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_rounded_maroon"
                    android:backgroundTint="@color/colorCategoryBg"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp"
                    android:text="@string/address_label_office"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chipOther"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_rounded_maroon"
                    android:backgroundTint="@color/colorCategoryBg"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp"
                    android:text="@string/address_label_other"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Full Name -->
            <TextView
                style="@style/TextAppearance.Saive.Nav"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/label_full_name"
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etFullName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:hint="@string/hint_full_name"
                android:inputType="textPersonName"
                android:paddingHorizontal="16dp"
                android:textColor="@color/colorNoirBlack"
                android:textSize="14sp" />

            <!-- Phone Number -->
            <TextView
                style="@style/TextAppearance.Saive.Nav"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/label_phone_number"
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp" />

            <LinearLayout
                android:baselineAligned="false"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+84"
                    android:textColor="@color/colorSand"
                    android:textSize="14sp"
                    android:paddingEnd="8dp"
                    android:paddingStart="0dp" />

                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="@string/hint_phone_remaining"
                    android:inputType="phone"
                    android:maxLength="9"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- City, District, Ward -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <!-- Province Selector -->
                <TextView
                    style="@style/TextAppearance.Saive.Nav"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_city"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp" />

                <RelativeLayout
                    android:id="@+id/btnCitySelector"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:id="@+id/tvSelectedCity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@+id/ivCityArrow"
                        android:text="@string/hint_choose_city"
                        android:textColor="@color/colorNoirBlack"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/ivCityArrow"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        app:icon="@drawable/ic_arrow_right"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="@color/white"
                        app:cornerRadius="16dp"
                        android:backgroundTint="@color/colorMaroon" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/btnOpenMap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_gravity="end"
                    android:text="@string/address_select_map"
                    android:textColor="@color/colorMaroon"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:padding="4dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- District Selector -->
                <TextView
                    style="@style/TextAppearance.Saive.Nav"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/label_district"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp" />

                <RelativeLayout
                    android:id="@+id/btnDistrictSelector"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:id="@+id/tvSelectedDistrict"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@+id/ivDistrictArrow"
                        android:text="@string/hint_choose_district"
                        android:textColor="@color/colorNoirBlack"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/ivDistrictArrow"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        app:icon="@drawable/ic_arrow_right"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="@color/white"
                        app:cornerRadius="16dp"
                        android:backgroundTint="@color/colorMaroon" />
                </RelativeLayout>

                <!-- Ward Selector -->
                <TextView
                    style="@style/TextAppearance.Saive.Nav"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/label_ward"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp" />

                <RelativeLayout
                    android:id="@+id/btnWardSelector"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:id="@+id/tvSelectedWard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@+id/ivWardArrow"
                        android:text="@string/hint_choose_ward"
                        android:textColor="@color/colorNoirBlack"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/ivWardArrow"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        app:icon="@drawable/ic_arrow_right"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="@color/white"
                        app:cornerRadius="16dp"
                        android:backgroundTint="@color/colorMaroon" />
                </RelativeLayout>

            </LinearLayout>

            <!-- Street Address (Now at the end) -->
            <TextView
                style="@style/TextAppearance.Saive.Nav"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/label_address"
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etStreet"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:gravity="top"
                android:hint="@string/hint_street_address"
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textColor="@color/colorNoirBlack"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/cbDefault"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:buttonTint="@color/colorMaroon"
                android:text="@string/address_set_default"
                android:textColor="@color/colorNoirBlack"
                android:textSize="14sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorMaroon"
        android:paddingHorizontal="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSaveAddress"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_rounded_white_8dp"
                android:backgroundTint="#20FFFFFF"
                android:stateListAnimator="@null"
                android:text="@string/address_save"
                android:textAllCaps="false"
                android:textColor="@color/colorButtonText"
                android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>