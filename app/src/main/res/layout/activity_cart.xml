<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorCotton"
    tools:ignore="Overdraw">

    <LinearLayout
                tools:ignore="UseCompoundDrawables"
                android:baselineAligned="false"
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorHeaderBg"
        android:elevation="@dimen/elevation_small"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_large"
        android:paddingTop="@dimen/spacing_54"
        android:paddingBottom="@dimen/spacing_medium"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="@dimen/icon_size_nav"
            android:layout_height="@dimen/icon_size_nav"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            app:tint="@color/colorHeaderContent"
            android:contentDescription="@null"/>

        <TextView
            style="@style/TextAppearance.Saive.SectionHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/spacing_xxlarge"
            android:layout_weight="1"
            android:gravity="center"
            android:letterSpacing="0.02"
            android:text="@string/cart_title"
            android:textColor="@color/colorHeaderContent"
            android:textSize="@dimen/text_size_18" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCartItems"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_large"
        app:layout_constraintBottom_toTopOf="@id/checkoutContainer"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        tools:listitem="@layout/item_favorite" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyStateCart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/checkoutContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerContainer">

        <ImageView
            android:layout_width="@dimen/spacing_120"
            android:layout_height="@dimen/spacing_120"
            android:src="@drawable/emtycard"
            android:alpha="0.5"
            android:contentDescription="@null"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_medium"
            style="@style/TextAppearance.Saive.Caption"
            android:text="@string/cart_empty_error"
            android:textSize="@dimen/text_size_16" />
    </LinearLayout>

    <!-- Checkout Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/checkoutContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorContactCardBg"
        android:paddingHorizontal="@dimen/spacing_large"
        android:paddingTop="@dimen/screen_padding"
        android:paddingBottom="@dimen/spacing_large"
        android:elevation="@dimen/elevation_medium"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <!-- Expandable Summary Details -->
        <LinearLayout
            android:id="@+id/layoutExpandableDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Coupon Section -->
            <LinearLayout
                tools:ignore="UseCompoundDrawables"
                android:baselineAligned="false"
                android:id="@+id/couponContainer"
                android:layout_width="match_parent"
                android:layout_height="@dimen/fab_size"
                android:layout_marginBottom="@dimen/screen_padding"
                android:background="@drawable/bg_rounded_white_8dp"
                android:backgroundTint="@color/colorLinen"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/spacing_medium"
                android:paddingEnd="@dimen/spacing_6">

                <ImageView
                    android:layout_width="@dimen/icon_size_20"
                    android:layout_height="@dimen/icon_size_20"
                    android:src="@drawable/ic_coupon"
                    app:tint="@color/colorTextSecondary"
                    android:contentDescription="@null"/>

                <EditText
                    android:id="@+id/etCoupon"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_12"
                    android:background="@android:color/transparent"
                    android:hint="@string/promo_code_hint"
                    android:autofillHints="none"
                    android:imeOptions="actionDone"
                    android:inputType="textCapCharacters"
                    android:maxLines="1"
                    style="@style/TextAppearance.Saive.Nav"
                    android:textSize="@dimen/text_size_13"
                    android:letterSpacing="0.05"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextSecondary" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnApplyCoupon"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/icon_size_large"
                    android:background="@drawable/bg_rounded_white_8dp"
                    android:backgroundTint="@color/colorContactCardContent"
                    android:text="@string/btn_apply"
                    android:textAllCaps="true"
                    android:textColor="@color/colorContactCardBg"
                    android:textSize="@dimen/text_size_caption"
                    android:textStyle="bold"
                    android:paddingHorizontal="@dimen/screen_padding"
                    android:elevation="@dimen/elevation_tiny" />
            </LinearLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_12">
                <TextView
                    android:layout_width="match_parent"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/tvSubtotal"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    style="@style/TextAppearance.Saive.Caption"
                    android:text="@string/label_item_total"
                    android:textColor="@color/colorContactCardLabel"
                    android:textSize="@dimen/text_size_14" />
                <TextView
                    android:id="@+id/tvSubtotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    style="@style/TextAppearance.Saive.Nav"
                    tools:text="0 ₫"
                    android:textColor="@color/colorContactCardContent"
                    android:textSize="@dimen/text_size_body" />
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/layoutDiscount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_12"
                android:visibility="gone">
                <TextView
                    android:layout_width="match_parent"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/tvDiscountValue"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    style="@style/TextAppearance.Saive.Caption"
                    android:text="@string/label_discount"
                    android:textColor="@color/colorContactCardLabel"
                    android:textSize="@dimen/text_size_14" />
                <TextView
                    android:id="@+id/tvDiscountValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    style="@style/TextAppearance.Saive.Nav"
                    tools:text="-0 ₫"
                    android:textColor="@color/colorGreen"
                    android:textSize="@dimen/text_size_body" />
            </RelativeLayout>

            <RelativeLayout
                tools:ignore="RelativeOverlap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_12">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/tvDeliveryFree"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    style="@style/TextAppearance.Saive.Caption"
                    android:text="@string/label_delivery"
                    android:textColor="@color/colorContactCardLabel"
                    android:textSize="@dimen/text_size_14" />
                <TextView
                    android:id="@+id/tvDeliveryFree"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    style="@style/TextAppearance.Saive.Nav"
                    android:text="@string/label_free"
                    android:textColor="@color/colorContactCardLabel"
                    android:textSize="@dimen/text_size_14" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/colorLinen"
                android:layout_marginBottom="@dimen/spacing_medium"
                android:alpha="0.3" />
        </LinearLayout>

        <!-- Main Total Row (Always Visible) -->
        <LinearLayout
                tools:ignore="UseCompoundDrawables"
                android:baselineAligned="false"
            android:id="@+id/layoutTotalToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/small_padding"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            app:layout_constraintTop_toBottomOf="@id/layoutExpandableDetails">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/TextAppearance.Saive.Nav"
                android:text="@string/label_total"
                android:letterSpacing="0.02"
                android:textColor="@color/colorContactCardContent"
                android:textSize="@dimen/text_size_17"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTotalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_12"
                style="@style/TextAppearance.Saive.Nav"
                tools:text="0 ₫"
                android:textStyle="bold"
                android:textColor="@color/colorContactCardContent"
                android:textSize="@dimen/text_size_22" />

            <ImageView
                android:id="@+id/ivExpandArrow"
                android:layout_width="@dimen/icon_size_20"
                android:layout_height="@dimen/icon_size_20"
                android:src="@drawable/ic_chevron_down"
                app:tint="@color/colorContactCardContent"
                android:contentDescription="@null"/>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCheckout"
            android:layout_width="match_parent"
            android:layout_height="@dimen/fab_size"
            android:layout_marginTop="@dimen/spacing_medium"
            android:background="@drawable/bg_rounded_white_8dp"
            android:backgroundTint="@color/colorContactCardContent"
            android:text="@string/btn_payment"
            android:textAllCaps="false"
            style="@style/TextAppearance.Saive.Nav"
            android:textColor="@color/colorContactCardBg"
            android:textSize="@dimen/text_size_16"
            android:textStyle="bold"
            android:stateListAnimator="@null"
            app:layout_constraintTop_toBottomOf="@id/layoutTotalToggle"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- BOTTOM NAVIGATION -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorHeaderBg"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
                android:baselineAligned="false"
            android:id="@+id/navItemsContainer"
            android:layout_width="match_parent"
            android:layout_height="@dimen/nav_bar_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/navFavorite"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="@dimen/icon_size_nav"
                    android:layout_height="@dimen/icon_size_nav"
                    android:src="@drawable/ic_favorite"
                    app:tint="@color/colorOnMaroonSecondary"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_favorite"
                    style="@style/TextAppearance.Saive.Nav"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/colorOnMaroonSecondary" />
            </LinearLayout>

            <!-- WARDROBE -->
            <LinearLayout
                android:id="@+id/navWardrobe"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="@dimen/icon_size_nav"
                    android:layout_height="@dimen/icon_size_nav"
                    android:src="@drawable/hangericon"
                    app:tint="@color/colorOnMaroonSecondary"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_wardrobe"
                    style="@style/TextAppearance.Saive.Nav"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/colorOnMaroonSecondary" />
            </LinearLayout>

            <!-- Item 2: HOME (ACTIVE AREA) -->
            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/spacing_large" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Saive.Nav"
                    android:text=" "
                    android:visibility="invisible"/>
            </LinearLayout>

            <!-- NOTIFICATIONS -->
            <FrameLayout
                android:id="@+id/navNotify"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_size_nav"
                        android:layout_height="@dimen/icon_size_nav"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/colorOnMaroonSecondary"
                        android:contentDescription="@null"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        style="@style/TextAppearance.Saive.Nav"
                        android:text="@string/nav_notify"
                        android:textColor="@color/colorOnMaroonSecondary" />
                </LinearLayout>

            </FrameLayout>

            <!-- PROFILE -->
            <LinearLayout
                android:id="@+id/navProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="@dimen/icon_size_nav"
                    android:layout_height="@dimen/icon_size_nav"
                    android:src="@drawable/ic_profile"
                    app:tint="@color/colorOnMaroonSecondary"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_profile"
                    style="@style/TextAppearance.Saive.Nav"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/colorOnMaroonSecondary" />
            </LinearLayout>

        </LinearLayout>

        <!-- SELECTION CIRCLE -->
        <FrameLayout
            android:id="@+id/centerActionButton"
            android:layout_width="@dimen/center_action_size"
            android:layout_height="@dimen/center_action_size"
            android:background="@drawable/bg_circle_white"
            android:elevation="@dimen/elevation_large"
            android:alpha="0.8"
            android:transitionName="nav_circle"
            app:layout_constraintBottom_toBottomOf="@id/navItemsContainer"
            app:layout_constraintTop_toTopOf="@id/navItemsContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="@dimen/spacing_medium"
                android:scaleType="fitCenter"
                android:src="@drawable/saive_logo"
                app:tint="@color/colorAccentBrand"
                android:contentDescription="@null"/>

        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>