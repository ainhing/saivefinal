<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="NestedWeights,Overdraw"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorCotton"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
                android:baselineAligned="false"
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorCotton"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_large"
        android:paddingTop="54dp"
        android:paddingBottom="12dp"
        android:translationZ="10dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            app:tint="@color/colorNoirBlack"
            android:contentDescription="@null"/>

        <FrameLayout
            android:id="@+id/btnCart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_cart"
                app:tint="@color/colorNoirBlack"
                android:contentDescription="@null"/>

            <TextView
                android:id="@+id/tvCartBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="-2dp"
                android:layout_marginEnd="-4dp"
                android:background="@drawable/bg_rounded_white_8dp"
                android:backgroundTint="@color/colorMaroon"
                android:gravity="center"
                android:minWidth="14dp"
                android:minHeight="14dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                tools:text="0"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />
        </FrameLayout>

        <LinearLayout
                android:baselineAligned="false"
            android:id="@+id/searchContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/colorNoirBlack"
                android:contentDescription="@null"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_medium"
                android:layout_weight="1"
                style="@style/TextAppearance.Saive.Nav"
                android:text="@string/nav_search"
                android:textColor="@color/colorNoirBlack" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            style="@style/TextAppearance.Saive.Logo"
            android:text="@string/app_name_caps" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/heroSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="40dp">

                <ImageView
                    android:id="@+id/ivHeroLeft"
                    android:layout_width="160dp"
                    android:layout_height="220dp"
                    android:layout_marginTop="40dp"
                    android:scaleType="centerCrop"
                    tools:src="@drawable/banner1"
                    app:layout_constraintEnd_toStartOf="@+id/ivHeroRight"
                    app:layout_constraintHorizontal_bias="0.3"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:contentDescription="@null"/>

                <ImageView
                    android:id="@+id/ivHeroRight"
                    android:layout_width="160dp"
                    android:layout_height="220dp"
                    android:layout_marginTop="60dp"
                    android:scaleType="centerCrop"
                    tools:src="@drawable/banner2"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/ivHeroLeft"
                    app:layout_constraintTop_toTopOf="parent"
                    android:contentDescription="@null"/>

                <TextView
                    android:id="@+id/tvHeadline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:fontFamily="serif"
                    android:gravity="center"
                    android:text="@string/col_monochrome_headline"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/ivHeroRight" />

                <TextView
                    android:id="@+id/tvSubHeadline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:paddingHorizontal="40dp"
                    android:text="@string/col_subheadline_default"
                    android:textColor="@color/colorGrayText"
                    android:textSize="14sp"
                    app:layout_constraintTop_toBottomOf="@id/tvHeadline" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShopAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:backgroundTint="@color/colorMaroon"
                    android:paddingHorizontal="32dp"
                    android:text="@string/col_btn_shop"
                    android:textColor="@color/white"
                    app:cornerRadius="24dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvSubHeadline" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:baselineAligned="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/colorOnMaroonContainer"
                android:orientation="horizontal"
                android:paddingVertical="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_hanger"
                        app:tint="@color/colorMaroon"
                        android:contentDescription="@null"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/col_feature_1"
                        android:textSize="11sp"
                        android:textColor="@color/colorNoirBlack" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_check_circle"
                        app:tint="@color/colorMaroon"
                        android:contentDescription="@null"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/col_feature_2"
                        android:textSize="11sp"
                        android:textColor="@color/colorNoirBlack" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_pin_drop"
                        app:tint="@color/colorMaroon"
                        android:contentDescription="@null"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/col_feature_3"
                        android:textSize="11sp"
                        android:textColor="@color/colorNoirBlack" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_heart_thin"
                        app:tint="@color/colorMaroon"
                        android:contentDescription="@null"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/col_feature_4"
                        android:textSize="11sp"
                        android:textColor="@color/colorNoirBlack" />
                </LinearLayout>
            </LinearLayout>

            <!-- Secondary Info Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="32dp">

                <TextView
                    android:id="@+id/tvWhyTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/col_why_saive"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvWhyDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="@string/col_why_desc"
                    android:textColor="@color/colorGrayText"
                    android:textSize="14sp"
                    app:layout_constraintTop_toBottomOf="@id/tvWhyTitle" />

                <ImageView
                    android:id="@+id/ivSectionModel"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginTop="24dp"
                    android:scaleType="centerCrop"
                    tools:src="@drawable/model2"
                    app:layout_constraintTop_toBottomOf="@id/tvWhyDesc"
                    android:contentDescription="@null"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Products List Section -->
            <LinearLayout
                android:id="@+id/productSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="60dp"
                android:background="@color/colorIvory">

                <TextView
                    android:id="@+id/tvCollectionProductsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/col_shop_collection"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCollectionProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    tools:listitem="@layout/item_grid_product"
                    tools:spanCount="2" />

                <ProgressBar
                    android:id="@+id/pbLoading"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="32dp"
                    android:indeterminateTint="@color/colorMaroon"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvEmptyProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="40dp"
                    android:gravity="center"
                    android:text="@string/col_empty_products"
                    android:textColor="@color/colorGrayText"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/colorNoirBlack"
                android:orientation="vertical"
                android:padding="40dp"
                android:paddingBottom="40dp"
                android:gravity="center">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="30dp"
                    android:src="@drawable/saive_logo"
                    app:tint="@color/white"
                    android:contentDescription="@null"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/col_copyright"
                    android:textColor="@color/colorTransWhite"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM NAVIGATION -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorMaroon"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
                android:baselineAligned="false"
            android:id="@+id/navItemsContainer"
            android:layout_width="match_parent"
            android:layout_height="@dimen/nav_bar_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/navFavorite"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="@dimen/icon_size_nav"
                    android:layout_height="@dimen/icon_size_nav"
                    android:src="@drawable/ic_favorite"
                    app:tint="@color/colorOnMaroonSecondary"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_favorite"
                    style="@style/TextAppearance.Saive.Nav"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/colorOnMaroonSecondary" />
            </LinearLayout>

            <!-- WARDROBE -->
            <LinearLayout
                android:id="@+id/navWardrobe"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="@dimen/icon_size_nav"
                    android:layout_height="@dimen/icon_size_nav"
                    android:src="@drawable/hangericon"
                    app:tint="@color/colorOnMaroonSecondary"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_wardrobe"
                    style="@style/TextAppearance.Saive.Nav"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/colorOnMaroonSecondary" />
            </LinearLayout>

            <!-- Item 2: HOME (PLACEHOLDER) -->
            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Saive.Nav"
                    android:text=" "
                    android:visibility="invisible"/>
            </LinearLayout>

            <!-- NOTIFICATIONS -->
            <FrameLayout
                android:id="@+id/navNotify"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_size_nav"
                        android:layout_height="@dimen/icon_size_nav"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/colorOnMaroonSecondary"
                        android:contentDescription="@null"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        style="@style/TextAppearance.Saive.Nav"
                        android:text="@string/nav_notify"
                        android:textColor="@color/colorOnMaroonSecondary" />
                </LinearLayout>

                <View
                    android:id="@+id/notificationBadge"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="10dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_rounded_white_8dp"
                    android:backgroundTint="@color/colorSand"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- PROFILE -->
            <LinearLayout
                android:id="@+id/navProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="@dimen/icon_size_nav"
                    android:layout_height="@dimen/icon_size_nav"
                    android:src="@drawable/ic_profile"
                    app:tint="@color/colorOnMaroonSecondary"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_profile"
                    style="@style/TextAppearance.Saive.Nav"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/colorOnMaroonSecondary" />
            </LinearLayout>

        </LinearLayout>

        <!-- SELECTION CIRCLE (At Home - Index 2 - Bias 0.5) -->
        <FrameLayout
            android:id="@+id/centerActionButton"
            android:layout_width="@dimen/center_action_size"
            android:layout_height="@dimen/center_action_size"
            android:background="@drawable/bg_circle_white"
            android:elevation="24dp"
            android:alpha="0.8"
            android:transitionName="nav_circle"
            app:layout_constraintBottom_toBottomOf="@id/navItemsContainer"
            app:layout_constraintTop_toTopOf="@id/navItemsContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:scaleType="fitCenter"
                android:src="@drawable/saive_logo"
                app:tint="@color/colorMaroon"
                android:contentDescription="@null"/>

        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>