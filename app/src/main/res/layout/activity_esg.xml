<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorCotton"
    tools:ignore="TooManyViews">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/esgHeaderBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorHeaderBg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="52dp"
        android:paddingBottom="14dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnEsgBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/colorHeaderContent"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_esg_research"
                android:textColor="@color/colorHeaderContent"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/esg_subtitle"
                android:textColor="@color/colorHeaderContent"
                android:textSize="10sp"
                android:alpha="0.7"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌿"
            android:textSize="22sp" />
    </LinearLayout>

    <!-- Tab Bar -->
    <LinearLayout
        android:id="@+id/esgTabBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/colorHeaderBg"
        app:layout_constraintTop_toBottomOf="@id/esgHeaderBar">

        <Button
            android:id="@+id/btnTabSearch"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/esg_tab_search"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnMaroon" />

        <View
            android:layout_width="0.5dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:background="@color/colorLinen"
            android:alpha="0.5" />

        <Button
            android:id="@+id/btnTabCompare"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/esg_tab_compare"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnMaroonSecondary" />

        <View
            android:layout_width="0.5dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:background="@color/colorLinen"
            android:alpha="0.5" />

        <Button
            android:id="@+id/btnTabSimulate"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/esg_tab_simulate"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnMaroonSecondary" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:id="@+id/esgTabDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorMaroon"
        android:alpha="0.3"
        app:layout_constraintTop_toBottomOf="@id/esgTabBar" />

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/pbSearch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/esgTabDivider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Scroll Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/esgTabDivider"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="40dp">

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- PANEL 1: TRA CỨU -->
            <!-- ══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/panelSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Section title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/esg_search_title"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/esg_search_subtitle"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="11sp"
                    android:alpha="0.55"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="14dp" />

                <!-- Search input card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_material_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/esg_company_name_label"
                        android:textColor="@color/colorNoirBlack"
                        android:textSize="10sp"
                        android:alpha="0.5"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/etSearchCompany"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="@string/esg_search_hint"
                        android:textSize="14sp"
                        android:background="@drawable/bg_edittext"
                        android:paddingHorizontal="12dp"
                        android:inputType="text"
                        android:imeOptions="actionSearch"
                        android:textColor="@color/colorNoirBlack"
                        android:textColorHint="#99000000" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/esg_year_label"
                        android:textColor="@color/colorNoirBlack"
                        android:textSize="10sp"
                        android:alpha="0.5"
                        android:letterSpacing="0.1"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="6dp" />

                    <Spinner
                        android:id="@+id/spinnerYear"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_edittext"
                        android:paddingHorizontal="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDoSearch"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="14dp"
                        android:text="@string/esg_search_btn"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="@color/colorMaroon"
                        android:textColor="@color/colorButtonText"
                        app:cornerRadius="12dp" />
                </LinearLayout>

                <!-- Results -->
                <LinearLayout
                    android:id="@+id/searchResultContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- PANEL 2: SO SÁNH -->
            <!-- ══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/panelCompare"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/esg_compare_title"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/esg_compare_subtitle"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="11sp"
                    android:alpha="0.55"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_material_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/esg_company1_label"
                        android:textColor="@color/colorMaroon"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="6dp" />

                    <Spinner
                        android:id="@+id/spinnerCmp1"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_edittext"
                        android:paddingHorizontal="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/esg_company2_label"
                        android:textColor="@color/colorMaroon"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="6dp" />

                    <Spinner
                        android:id="@+id/spinnerCmp2"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_edittext"
                        android:paddingHorizontal="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/esg_year_label"
                        android:textColor="@color/colorNoirBlack"
                        android:textSize="10sp"
                        android:alpha="0.5"
                        android:letterSpacing="0.1"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="6dp" />

                    <Spinner
                        android:id="@+id/spinnerCmpYear"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_edittext"
                        android:paddingHorizontal="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDoCompare"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="14dp"
                        android:text="@string/esg_compare_btn"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="@color/colorMaroon"
                        android:textColor="@color/colorButtonText"
                        app:cornerRadius="12dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/compareResultContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- PANEL 3: MÔ PHỎNG -->
            <!-- ══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/panelSimulate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/esg_simulate_title"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/esg_simulate_subtitle"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="11sp"
                    android:alpha="0.55"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_material_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/esg_overall_label"
                        android:textColor="@color/colorNoirBlack"
                        android:textSize="10sp"
                        android:alpha="0.5"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/etSimEsgOverall"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="@string/esg_overall_hint"
                        android:textSize="14sp"
                        android:background="@drawable/bg_edittext"
                        android:paddingHorizontal="12dp"
                        android:inputType="numberDecimal"
                        android:textColor="@color/colorNoirBlack"
                        android:textColorHint="#99000000" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/esg_industry_label"
                        android:textColor="@color/colorNoirBlack"
                        android:textSize="10sp"
                        android:alpha="0.5"
                        android:letterSpacing="0.1"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="6dp" />

                    <Spinner
                        android:id="@+id/spinnerSimIndustry"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_edittext"
                        android:paddingHorizontal="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/esg_region_label"
                        android:textColor="@color/colorNoirBlack"
                        android:textSize="10sp"
                        android:alpha="0.5"
                        android:letterSpacing="0.1"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="6dp" />

                    <Spinner
                        android:id="@+id/spinnerSimRegion"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_edittext"
                        android:paddingHorizontal="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDoSimulate"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="14dp"
                        android:text="@string/esg_predict_btn"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="@color/colorMaroon"
                        android:textColor="@color/colorButtonText"
                        app:cornerRadius="12dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/simulateResultContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
