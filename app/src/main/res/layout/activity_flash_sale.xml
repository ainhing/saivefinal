<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="NestedWeights,Overdraw"
    android:id="@+id/flashSaleRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorCotton"
    android:clipChildren="false"
    android:clipToPadding="false">


    <LinearLayout
                android:baselineAligned="false"
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorCotton"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_large"
        android:paddingTop="54dp"
        android:paddingBottom="12dp"
        android:translationZ="10dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            app:tint="@color/colorNoirBlack"
            android:contentDescription="@null"/>

        <FrameLayout
            android:id="@+id/btnCart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_cart"
                app:tint="@color/colorNoirBlack"
                android:contentDescription="@null"/>

            <TextView
                android:id="@+id/tvCartBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="-2dp"
                android:layout_marginEnd="-4dp"
                android:background="@drawable/bg_rounded_white_8dp"
                android:backgroundTint="@color/colorMaroon"
                android:gravity="center"
                android:minWidth="14dp"
                android:minHeight="14dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:text="0"
                android:textColor="@color/colorOnMaroon"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />
        </FrameLayout>

        <LinearLayout
                android:baselineAligned="false"
            android:id="@+id/searchContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/colorNoirBlack"
                android:contentDescription="@null"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_medium"
                android:layout_weight="1"
                style="@style/TextAppearance.Saive.Nav"
                android:text="@string/nav_search"
                android:textColor="@color/colorNoirBlack" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            style="@style/TextAppearance.Saive.Logo"
            android:text="SAIVE" />

    </LinearLayout>

    <!-- Dark Flash Sale Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/flashSaleContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/colorFlashSaleBg"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <!-- Flash Sale Header -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            style="@style/TextAppearance.Saive.Label"
            android:text="@string/label_flash_sale"
            android:textColor="@color/colorFlashSaleContentSecondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvFullSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="16dp"
            style="@style/TextAppearance.Saive.Header"
            android:text="@string/label_midnight_curation"
            android:textColor="@color/colorFlashSaleContent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/timerContainer"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintHorizontal_bias="0" />

        <LinearLayout
                android:baselineAligned="false"
            android:id="@+id/timerContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="@id/tvFullSubtitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvFullSubtitle">

            <TextView
                android:id="@+id/tvHour"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_timer_box"
                android:gravity="center"
                android:text="00"
                android:textColor="@color/colorCountdownText"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="4dp"
                android:text=":"
                android:textColor="@color/colorCountdownText"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMinute"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_timer_box"
                android:gravity="center"
                android:text="11"
                android:textColor="@color/colorCountdownText"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="4dp"
                android:text=":"
                android:textColor="@color/colorCountdownText"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSecond"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_timer_box"
                android:gravity="center"
                android:text="33"
                android:textColor="@color/colorCountdownText"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <View
            android:id="@+id/headerDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="24dp"
            android:background="@color/white"
            android:alpha="0.1"
            app:layout_constraintTop_toBottomOf="@id/tvFullSubtitle" />

        <!-- Product Grid inside dark container -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFlashSaleProducts"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerDivider"
            tools:listitem="@layout/item_flash_sale_product" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- BOTTOM NAVIGATION -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorMaroon"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
                android:baselineAligned="false"
            android:id="@+id/navItemsContainer"
            android:layout_width="match_parent"
            android:layout_height="@dimen/nav_bar_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/navFavorite"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="@dimen/icon_size_nav"
                    android:layout_height="@dimen/icon_size_nav"
                    android:src="@drawable/ic_favorite"
                    app:tint="@color/colorOnMaroonSecondary"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_favorite"
                    style="@style/TextAppearance.Saive.Nav"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/colorOnMaroonSecondary" />
            </LinearLayout>

            <!-- WARDROBE -->
            <LinearLayout
                android:id="@+id/navWardrobe"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="@dimen/icon_size_nav"
                    android:layout_height="@dimen/icon_size_nav"
                    android:src="@drawable/hangericon"
                    app:tint="@color/colorOnMaroonSecondary"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_wardrobe"
                    style="@style/TextAppearance.Saive.Nav"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/colorOnMaroonSecondary" />
            </LinearLayout>

            <!-- Item 2: HOME (PLACEHOLDER) -->
            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Saive.Nav"
                    android:text=" "
                    android:visibility="invisible"/>
            </LinearLayout>

            <!-- NOTIFICATIONS -->
            <FrameLayout
                android:id="@+id/navNotify"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_size_nav"
                        android:layout_height="@dimen/icon_size_nav"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/colorOnMaroonSecondary"
                        android:contentDescription="@null"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        style="@style/TextAppearance.Saive.Nav"
                        android:text="@string/nav_notify"
                        android:textColor="@color/colorOnMaroonSecondary" />
                </LinearLayout>

                <View
                    android:id="@+id/notificationBadge"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="10dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_rounded_white_8dp"
                    android:backgroundTint="@color/colorSand"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- PROFILE -->
            <LinearLayout
                android:id="@+id/navProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="@dimen/icon_size_nav"
                    android:layout_height="@dimen/icon_size_nav"
                    android:src="@drawable/ic_profile"
                    app:tint="@color/colorOnMaroonSecondary"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_profile"
                    style="@style/TextAppearance.Saive.Nav"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/colorOnMaroonSecondary" />
            </LinearLayout>

        </LinearLayout>

        <!-- SELECTION CIRCLE (At Home - Index 2 - Bias 0.5) -->
        <FrameLayout
            android:id="@+id/centerActionButton"
            android:layout_width="@dimen/center_action_size"
            android:layout_height="@dimen/center_action_size"
            android:background="@drawable/bg_circle_white"
            android:elevation="24dp"
            android:alpha="0.8"
            android:transitionName="nav_circle"
            app:layout_constraintBottom_toBottomOf="@id/navItemsContainer"
            app:layout_constraintTop_toTopOf="@id/navItemsContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:scaleType="fitCenter"
                android:src="@drawable/saive_logo"
                app:tint="@color/colorMaroon"
                android:contentDescription="@null"/>

        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>