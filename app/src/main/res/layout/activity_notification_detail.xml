<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorCotton"
    tools:ignore="Overdraw">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorCotton"
        android:paddingTop="54dp"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <RelativeLayout
                tools:ignore="RelativeOverlap"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginEnd="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:rotation="180"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="@color/colorNoirBlack"
                    android:contentDescription="@string/nav_back"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/btnBack"
                    android:layout_toStartOf="@id/ivShare"
                    android:layout_centerVertical="true"
                    android:gravity="center"
                    android:fontFamily="serif"
                    android:letterSpacing="0.1"
                    android:text="@string/bulletin_header"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivShare"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_share"
                    app:tint="@color/colorNoirBlack"
                    android:contentDescription="@null"/>

            </RelativeLayout>
        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <ImageView
                android:id="@+id/ivDetailImage"
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:scaleType="centerCrop"
                xmlns:tools="http://schemas.android.com/tools"
                tools:src="@drawable/atumncollection1"
                android:contentDescription="@null"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="24dp">

                <TextView
                    android:id="@+id/tvDetailTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="@string/notify_drop_title"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="26sp"
                    android:textStyle="italic" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:background="@color/colorMaroon" />

                <TextView
                    android:id="@+id/tvDetailTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:alpha="0.5"
                    android:fontFamily="sans-serif-light"
                    android:text="@string/posted_time"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDetailContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:alpha="0.8"
                    android:fontFamily="sans-serif-light"
                    android:lineSpacingExtra="10dp"
                    android:text="@string/notify_detail_description_placeholder"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="16sp" />

                <LinearLayout
                tools:ignore="UseCompoundDrawables"
                android:baselineAligned="false"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="240dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="0dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivSub1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            xmlns:tools="http://schemas.android.com/tools"
                            tools:src="@drawable/atumncollection2"
                            android:contentDescription="@null"/>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="240dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardCornerRadius="0dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivSub2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            xmlns:tools="http://schemas.android.com/tools"
                            tools:src="@drawable/model1"
                            android:contentDescription="@null"/>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivSub3"
                    android:layout_width="match_parent"
                    android:layout_height="350dp"
                    android:layout_marginTop="16dp"
                    android:scaleType="centerCrop"
                    xmlns:tools="http://schemas.android.com/tools"
                    tools:src="@drawable/banner2"
                    android:contentDescription="@null"/>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cvAction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    app:cardBackgroundColor="@color/colorMaroon"
                    app:cardCornerRadius="0dp"
                    app:cardElevation="4dp">

                    <TextView
                        android:id="@+id/tvActionText"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center"
                        android:letterSpacing="0.1"
                        android:text="@string/btn_explore_collection"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>