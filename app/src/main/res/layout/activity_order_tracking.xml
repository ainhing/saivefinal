<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBeigeBg"
    tools:ignore="Overdraw">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorMaroon"
        app:elevation="0dp">

        <LinearLayout
                android:baselineAligned="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="54dp"
            android:paddingBottom="8dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                app:tint="@color/white"
                android:contentDescription="@string/nav_back"/>

            <TextView
                style="@style/TextAppearance.Saive.SectionHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="40dp"
                android:gravity="center"
                android:text="@string/track_order_title"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:id="@+id/itemsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvSeeMore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_view_more_products"
                android:textColor="@color/colorMaroon"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:paddingVertical="8dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/track_order_title"
                android:textColor="@color/colorNoirBlack"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="match_parent"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/expectedDelivery"
                    android:layout_height="wrap_content"
                    android:text="@string/label_expected_delivery_date"
                    android:textColor="@color/colorGrayText"/>
                <TextView
                    android:id="@+id/expectedDelivery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    tools:text="03 Sep 2023"
                    android:textColor="@color/colorNoirBlack"
                    android:textStyle="bold"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="match_parent"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/orderId"
                    android:layout_height="wrap_content"
                    android:text="@string/label_tracking_id"
                    android:textColor="@color/colorGrayText"/>
                <TextView
                    android:id="@+id/orderId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    tools:text="TRK452126542"
                    android:textColor="@color/colorNoirBlack"
                    android:textStyle="bold"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="match_parent"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/paymentMethod"
                    android:layout_height="wrap_content"
                    android:text="@string/label_payment_method"
                    android:textColor="@color/colorGrayText"/>
                <TextView
                    android:id="@+id/paymentMethod"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    tools:text="Credit Card"
                    android:textColor="@color/colorNoirBlack"
                    android:textStyle="bold"/>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_shipping_address"
                    android:textColor="@color/colorGrayText"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:id="@+id/shippingAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="123 Fashion Ave, Design District, NY 10001, USA"
                    android:textColor="@color/colorNoirBlack"
                    android:textStyle="bold"
                    android:lineSpacingExtra="2dp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_order_status"
                android:textColor="@color/colorNoirBlack"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>

            <!-- Status Timeline -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Placed -->
                <LinearLayout
                android:baselineAligned="false"
                    android:id="@+id/stepPlaced"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                tools:ignore="UseCompoundDrawables"
                        android:layout_width="40dp"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <ImageView
                            android:id="@+id/circlePlaced"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_circle_black"
                            android:backgroundTint="@color/colorMaroon"
                            android:padding="4dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="@color/white"
                            android:contentDescription="@null"/>
                        <View
                            android:id="@+id/linePlaced"
                            android:layout_width="2dp"
                            android:layout_height="match_parent"
                            android:minHeight="40dp"
                            android:background="@color/colorMaroon" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:paddingBottom="24dp">
                        <TextView
                            android:id="@+id/textPlaced"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/order_placed"
                            android:textColor="@color/colorNoirBlack"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="23 Aug 2023, 04:25 PM"
                            android:textColor="@color/colorGrayText"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_all"
                        app:tint="@color/colorGrayText"
                        android:contentDescription="@null"/>
                </LinearLayout>

                <!-- In Progress -->
                <LinearLayout
                android:baselineAligned="false"
                    android:id="@+id/stepProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                tools:ignore="UseCompoundDrawables"
                        android:layout_width="40dp"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <ImageView
                            android:id="@+id/circleProgress"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_circle_black"
                            android:backgroundTint="@color/colorMaroon"
                            android:padding="4dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="@color/white"
                            android:contentDescription="@null"/>
                        <View
                            android:id="@+id/lineProgress"
                            android:layout_width="2dp"
                            android:layout_height="match_parent"
                            android:minHeight="40dp"
                            android:background="@color/colorLightGray" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:paddingBottom="24dp">
                        <TextView
                            android:id="@+id/textProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_in_progress"
                            android:textColor="@color/colorNoirBlack"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="23 Aug 2023, 09:54 PM"
                            android:textColor="@color/colorGrayText"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_package"
                        app:tint="@color/colorGrayText"
                        android:contentDescription="@null"/>
                </LinearLayout>

                <!-- Shipped -->
                <LinearLayout
                android:baselineAligned="false"
                    android:id="@+id/stepShipped"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                tools:ignore="UseCompoundDrawables"
                        android:layout_width="40dp"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <ImageView
                            android:id="@+id/circleShipped"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_circle_black"
                            android:backgroundTint="@color/colorLightGray"
                            android:padding="4dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="@color/white"
                            android:contentDescription="@null"/>
                        <View
                            android:id="@+id/lineShipped"
                            android:layout_width="2dp"
                            android:layout_height="match_parent"
                            android:minHeight="40dp"
                            android:background="@color/colorLightGray" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:paddingBottom="24dp">
                        <TextView
                            android:id="@+id/textShipped"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/order_status_shipped"
                            android:textColor="@color/colorGrayText"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="Expected 02 Sep 2023"
                            android:textColor="@color/colorGrayText"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_pin_drop"
                        app:tint="@color/colorGrayText"
                        android:contentDescription="@null"/>
                </LinearLayout>

                <!-- Delivered -->
                <LinearLayout
                android:baselineAligned="false"
                    android:id="@+id/stepDelivered"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                tools:ignore="UseCompoundDrawables"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <ImageView
                            android:id="@+id/circleDelivered"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_circle_black"
                            android:backgroundTint="@color/colorLightGray"
                            android:padding="4dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="@color/white"
                            android:contentDescription="@null"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:paddingBottom="24dp">
                        <TextView
                            android:id="@+id/textDelivered"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/order_delivered_success"
                            android:textColor="@color/colorGrayText"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="23 Aug 2023, 2023"
                            android:textColor="@color/colorGrayText"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_plus"
                        app:tint="@color/colorGrayText"
                        android:contentDescription="@null"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>