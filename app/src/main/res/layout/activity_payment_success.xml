<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
                tools:ignore="UseCompoundDrawables,Overdraw" xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorCotton"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <ImageView
        android:id="@+id/ivSuccess"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:src="@drawable/paymentsuccesful"
        android:scaleType="centerInside"
        android:contentDescription="@null"/>

    <TextView
        android:id="@+id/tvSuccessTitle"
        style="@style/TextAppearance.Saive.SectionHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/payment_success_title"
        android:textSize="22sp"
        android:letterSpacing="0.1"
        android:textColor="@color/colorNoirBlack"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvSuccessDesc"
        style="@style/TextAppearance.Saive.Label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/payment_success_desc"
        android:textSize="14sp"
        android:alpha="0.6"
        android:gravity="center"
        android:lineSpacingExtra="4dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnContinueShopping"
        style="@style/TextAppearance.Saive.Label"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="48dp"
        android:background="@drawable/bg_rounded_maroon_btn"
        android:text="@string/btn_continue_shopping"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        android:stateListAnimator="@null" />

    <TextView
        android:id="@+id/btnViewOrder"
        style="@style/TextAppearance.Saive.SectionHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/btn_view_order"
        android:textSize="14sp"
        android:textColor="@color/colorMaroon"
        android:letterSpacing="0.1" />

</LinearLayout>