<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="TooManyViews,Overdraw"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorCotton">

    <!-- Header Bar -->
    <LinearLayout
                android:baselineAligned="false"
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorHeaderBg"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_large"
        android:paddingTop="54dp"
        android:paddingBottom="14dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvProfileHeader"
            style="@style/TextAppearance.Saive.SectionHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.2"
            android:text="@string/profile_header"
            android:textColor="@color/colorHeaderContent"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/profileScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/headerContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- PART 1: IDENTITY -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:padding="4dp"
                    android:background="@drawable/bg_avatar_ring">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        tools:src="@drawable/model1"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Saive.Circle" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    style="@style/TextAppearance.Saive.Header"
                    android:textSize="22sp"
                    android:text="@string/profile_user_name"
                    android:textColor="@color/colorNoirBlack" />

                <TextView
                    android:id="@+id/tvUserLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    style="@style/TextAppearance.Saive.Light"
                    android:textSize="12sp"
                    android:text="@string/profile_location"
                    android:textColor="@color/colorNoirBlack"
                    android:alpha="0.8"
                    android:letterSpacing="0.05" />
            </LinearLayout>

            <!-- PART 2: STATS -->

            <!-- PART 3: GROUPS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:orientation="vertical"
                android:paddingHorizontal="24dp">

                <!-- ACCOUNT SETTINGS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Saive.Caption"
                    android:text="@string/label_account_settings"
                    android:textColor="@color/colorNoirBlack"
                    android:alpha="0.6"
                    android:textSize="11sp"
                    android:letterSpacing="0.2" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_material_card"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <LinearLayout
                        android:id="@+id/btnMyOrdersNew"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_menu_item"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_cart"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            style="@style/TextAppearance.Saive.Light"
                            android:text="@string/menu_my_orders"
                            android:textColor="@color/colorNoirBlack"
                            android:textSize="14sp" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_back"
                            android:rotation="180"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_marginHorizontal="16dp" android:background="@color/colorLinen" android:alpha="0.5" />

                    <LinearLayout
                tools:ignore="UseCompoundDrawables"
                        android:id="@+id/btnSavedCollections"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_menu_item"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_favorite"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            style="@style/TextAppearance.Saive.Light"
                            android:text="@string/menu_saved_collections"
                            android:textColor="@color/colorNoirBlack"
                            android:textSize="14sp" />
                        <TextView
                            android:id="@+id/tvSavedCollectionsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_circle_maroon"
                            android:paddingHorizontal="6dp"
                            tools:text="0"
                            android:textColor="@color/colorButtonText"
                            android:textSize="11sp"
                            android:gravity="center" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_back"
                            android:rotation="180"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_marginHorizontal="16dp" android:background="@color/colorLinen" android:alpha="0.5" />

                    <LinearLayout
                        android:id="@+id/btnMyCoupons"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_menu_item"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_coupon"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            style="@style/TextAppearance.Saive.Light"
                            android:text="@string/menu_my_coupons"
                            android:textColor="@color/colorNoirBlack"
                            android:textSize="14sp" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_back"
                            android:rotation="180"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_marginHorizontal="16dp" android:background="@color/colorLinen" android:alpha="0.5" />

                    <LinearLayout
                        android:id="@+id/btnAddressNew"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_menu_item"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_pin_drop"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            style="@style/TextAppearance.Saive.Light"
                            android:text="@string/menu_address"
                            android:textColor="@color/colorNoirBlack"
                            android:textSize="14sp" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_back"
                            android:rotation="180"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="@color/colorLinen" android:alpha="0.5" />

                    <LinearLayout
                        android:id="@+id/btnPaymentCards"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_menu_item"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_send"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            style="@style/TextAppearance.Saive.Light"
                            android:text="@string/menu_payment_cards"
                            android:textColor="@color/colorNoirBlack"
                            android:textSize="14sp" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_back"
                            android:rotation="180"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="@color/colorLinen" android:alpha="0.5" />

                    <LinearLayout
                tools:ignore="UseCompoundDrawables"
                        android:id="@+id/btnChangePassword"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_menu_item"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_lock_idle_lock"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                        <TextView
                            android:id="@+id/tvChangePassword"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            style="@style/TextAppearance.Saive.Light"
                            android:text="@string/change_password_title"
                            android:textColor="@color/colorNoirBlack"
                            android:textSize="14sp" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_back"
                            android:rotation="180"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- PREFERENCES -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    style="@style/TextAppearance.Saive.Caption"
                    android:text="@string/label_preferences"
                    android:textColor="@color/colorNoirBlack"
                    android:alpha="0.6"
                    android:textSize="11sp"
                    android:letterSpacing="0.2" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_material_card"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <LinearLayout
                tools:ignore="UseCompoundDrawables"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_notifications"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            style="@style/TextAppearance.Saive.Light"
                            android:text="@string/menu_notifications"
                            android:textColor="@color/colorNoirBlack"
                            android:textSize="14sp" />
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchNotifications"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:thumbTint="@color/colorAccentBrand"
                            app:trackTint="@color/colorNoirBlack" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="@color/colorLinen" android:alpha="0.5" />

                    <LinearLayout
                tools:ignore="UseCompoundDrawables"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_notifications"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>

                        <TextView
                            style="@style/TextAppearance.Saive.Light"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:text="@string/menu_dark_mode"
                            android:textColor="@color/colorNoirBlack"
                            android:textSize="14sp" />
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchDarkMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:thumbTint="@color/colorAccentBrand"
                            app:trackTint="@color/colorNoirBlack" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_marginHorizontal="16dp" android:background="@color/colorLinen" android:alpha="0.5" />

                    <LinearLayout
                tools:ignore="UseCompoundDrawables"
                        android:id="@+id/btnLanguageNew"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_menu_item"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_directions"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            style="@style/TextAppearance.Saive.Light"
                            android:text="@string/menu_language"
                            android:textColor="@color/colorNoirBlack"
                            android:textSize="14sp" />
                        <TextView
                            android:id="@+id/tvCurrentLanguage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            style="@style/TextAppearance.Saive.Light"
                            tools:text="English"
                            android:textColor="@color/colorNoirBlack"
                            android:alpha="0.6"
                            android:textSize="12sp" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_back"
                            android:rotation="180"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_marginHorizontal="16dp" android:background="@color/colorLinen" android:alpha="0.5" />

                    <LinearLayout
                        android:id="@+id/btnEsgResearch"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_menu_item"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_compass"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            style="@style/TextAppearance.Saive.Light"
                            android:text="@string/menu_esg_research"
                            android:textColor="@color/colorNoirBlack"
                            android:textSize="14sp" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_back"
                            android:rotation="180"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- SUPPORT & LEGAL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    style="@style/TextAppearance.Saive.Caption"
                    android:text="@string/label_support_legal"
                    android:textColor="@color/colorNoirBlack"
                    android:alpha="0.6"
                    android:textSize="11sp"
                    android:letterSpacing="0.2" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_material_card"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <LinearLayout
                        android:id="@+id/btnFAQ"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_menu_item"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_help"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            style="@style/TextAppearance.Saive.Light"
                            android:text="@string/menu_faq"
                            android:textColor="@color/colorNoirBlack"
                            android:textSize="14sp" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_back"
                            android:rotation="180"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_marginHorizontal="16dp" android:background="@color/colorLinen" android:alpha="0.5" />

                    <LinearLayout
                        android:id="@+id/btnContactUs"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_menu_item"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_call"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            style="@style/TextAppearance.Saive.Light"
                            android:text="@string/menu_contact_us"
                            android:textColor="@color/colorNoirBlack"
                            android:textSize="14sp" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_back"
                            android:rotation="180"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_marginHorizontal="16dp" android:background="@color/colorLinen" android:alpha="0.5" />

                    <LinearLayout
                        android:id="@+id/btnAbout"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_menu_item"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            style="@style/TextAppearance.Saive.Light"
                            android:text="@string/menu_about"
                            android:textColor="@color/colorNoirBlack"
                            android:textSize="14sp" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_back"
                            android:rotation="180"
                            app:tint="@color/colorNoirBlack"
                            android:contentDescription="@null"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_marginHorizontal="16dp" android:background="@color/colorLinen" android:alpha="0.5" android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/btnDeleteAccount"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_menu_item"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_delete"
                            app:tint="@color/colorAccentBrand"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            style="@style/TextAppearance.Saive.Light"
                            android:text="@string/menu_delete_account"
                            android:textColor="@color/colorAccentBrand"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- PART 4: LOGOUT -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogoutNew"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="48dp"
                android:text="@string/menu_logout"
                style="@style/TextAppearance.Saive.Nav"
                android:textColor="@color/colorButtonText"
                android:letterSpacing="0.2"
                app:cornerRadius="12dp"
                app:backgroundTint="@color/colorButtonBg"
                app:elevation="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                style="@style/TextAppearance.Saive.Caption"
                android:text="@string/label_saive_footer"
                android:textColor="@color/colorNoirBlack"
                android:textSize="11sp"
                android:alpha="0.7" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM NAVIGATION -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorHeaderBg"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
                android:baselineAligned="false"
            android:id="@+id/navItemsContainer"
            android:layout_width="match_parent"
            android:layout_height="@dimen/nav_bar_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/navFavorite"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="@dimen/icon_size_nav"
                    android:layout_height="@dimen/icon_size_nav"
                    android:src="@drawable/ic_favorite"
                    app:tint="@color/colorOnMaroonSecondary"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_favorite"
                    style="@style/TextAppearance.Saive.Nav"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/colorOnMaroonSecondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navWardrobe"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="@dimen/icon_size_nav"
                    android:layout_height="@dimen/icon_size_nav"
                    android:src="@drawable/hangericon"
                    app:tint="@color/colorOnMaroonSecondary"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_wardrobe"
                    style="@style/TextAppearance.Saive.Nav"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/colorOnMaroonSecondary" />
            </LinearLayout>

            <!-- Item 2: HOME (PLACEHOLDER) -->
            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Saive.Nav"
                    android:text=" "
                    android:visibility="invisible"/>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/navNotify"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="@dimen/icon_size_nav"
                        android:layout_height="@dimen/icon_size_nav"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/colorOnMaroonSecondary"
                        android:contentDescription="@null"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/nav_notify"
                        style="@style/TextAppearance.Saive.Nav"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/colorOnMaroonSecondary" />
                </LinearLayout>

                <View
                    android:id="@+id/notificationBadge"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="10dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_circle_nav"
                    android:visibility="gone" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/navProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="@dimen/icon_size_nav"
                    android:layout_height="@dimen/icon_size_nav"
                    android:src="@drawable/ic_profile"
                    app:tint="@color/colorHeaderContent"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_profile"
                    style="@style/TextAppearance.Saive.Nav"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/colorHeaderContent" />
            </LinearLayout>

        </LinearLayout>

        <FrameLayout
            android:id="@+id/centerActionButton"
            android:layout_width="@dimen/center_action_size"
            android:layout_height="@dimen/center_action_size"
            android:background="@drawable/bg_circle_white"
            android:elevation="24dp"
            android:alpha="0.8"
            android:transitionName="nav_circle"
            app:layout_constraintBottom_toBottomOf="@id/navItemsContainer"
            app:layout_constraintTop_toTopOf="@id/navItemsContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:scaleType="fitCenter"
                android:src="@drawable/saive_logo"
                app:tint="@color/colorAccentBrand"
                android:contentDescription="@null"/>
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>