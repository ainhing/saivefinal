<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorCotton">

    <!-- ── Header ── -->
    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_circle_white"
            android:backgroundTint="@color/colorTranslucentSurface"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            app:tint="@color/colorNoirBlack"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/recommend_title"
            android:textColor="@color/colorNoirBlack"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05" />

    </RelativeLayout>

    <!-- ── Scrollable content ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ── Source product card ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recommend_main_item"
                    android:textColor="@color/colorMaroon"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="sans-serif-medium" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMainProduct"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardCornerRadius="0dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/colorLinen"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/ivMainProduct"
                            android:layout_width="100dp"
                            android:layout_height="130dp"
                            android:scaleType="centerCrop"
                            android:background="@color/colorCotton"
                            android:contentDescription="@null"
                            tools:src="@drawable/model1" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="14dp">

                            <TextView
                                android:id="@+id/tvMainProductName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/colorNoirBlack"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.03"
                                android:maxLines="2"
                                android:ellipsize="end"
                                tools:text="SILK POLO SHIRT" />

                            <TextView
                                android:id="@+id/tvMainProductPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:textColor="@color/colorMaroon"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif"
                                tools:text="850,000 ₫" />

                            <!-- Style + Color tags row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/tvMainStyle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:paddingHorizontal="8dp"
                                    android:paddingVertical="3dp"
                                    android:background="@color/colorNoirBlack"
                                    android:textColor="@color/colorAlwaysWhite"
                                    android:textSize="9sp"
                                    android:letterSpacing="0.1"
                                    android:fontFamily="sans-serif-medium"
                                    android:visibility="gone"
                                    tools:text="MINIMALIST"
                                    tools:visibility="visible"/>

                                <TextView
                                    android:id="@+id/tvMainColors"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:textColor="@color/colorGrey"
                                    android:textSize="10sp"
                                    android:fontFamily="sans-serif-light"
                                    android:visibility="gone"
                                    tools:text="Cream · Black"
                                    tools:visibility="visible"/>

                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ── Divider with label ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/colorLinen"/>

                <TextView
                    android:id="@+id/tvSectionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:text="@string/label_complete_look"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="sans-serif-medium"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/colorLinen"/>

            </LinearLayout>

            <!-- ── Recommendations ── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecommendations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_recommendation_product" />

            <!-- ── Empty state ── -->
            <LinearLayout
                android:id="@+id/emptyView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="40dp"
                android:paddingHorizontal="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recommend_empty_toast"
                    android:textColor="@color/colorGrey"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── Bottom Action Bar ── -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddAllToCart"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="@color/colorMaroon"
            android:text="@string/btn_add_all_to_cart"
            android:textColor="@color/colorAlwaysWhite"
            android:textSize="14sp"
            android:letterSpacing="0.05"
            app:icon="@drawable/ic_cart"
            app:iconTint="@color/colorAlwaysWhite"
            app:iconGravity="textStart"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
