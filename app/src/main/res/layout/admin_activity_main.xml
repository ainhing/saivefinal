<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/colorCotton"
    tools:context=".admin.activities.AdminActivity"
    tools:ignore="Overdraw">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorCotton">

        <!-- Header -->
        <LinearLayout
                android:baselineAligned="false"
            android:id="@+id/adminHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="54dp"
            android:paddingBottom="20dp"
            android:gravity="center_vertical"
            android:background="@color/colorHeaderBg"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle_white"
                android:backgroundTint="?attr/colorSurface"
                android:elevation="2dp"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_menu"
                app:tint="@color/colorAccentBrand"
                android:contentDescription="@string/desc_menu"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/screen_padding"
                android:text="@string/admin_dashboard_title"
                style="@style/TextAppearance.Saive.SectionHeader"
                android:textSize="@dimen/text_size_18"
                android:textColor="@color/colorHeaderContent"
                android:letterSpacing="0.2" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAdminAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                tools:src="@drawable/model1"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Saive.Circle"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:overScrollMode="never"
            app:layout_constraintTop_toBottomOf="@id/adminHeader"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Stats Summary Cards Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                android:baselineAligned="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:layout_marginBottom="12dp"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="?attr/colorSurface"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/colorLinen">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/admin_stats_revenue"
                                    style="@style/TextAppearance.Saive.Caption"
                                    android:textColor="@color/colorSand"
                                    android:textSize="11sp" />
                                <TextView
                                    android:id="@+id/tvTotalRevenue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    tools:text="—"
                                    style="@style/TextAppearance.Saive.Header"
                                    android:textSize="18sp"
                                    android:textColor="@color/colorNoirBlack"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:layout_marginBottom="12dp"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/colorMaroon"
                            app:strokeWidth="0dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/admin_stats_orders"
                                    style="@style/TextAppearance.Saive.Caption"
                                    android:textColor="@color/colorLinen"
                                    android:alpha="0.8"
                                    android:textSize="11sp" />
                                <TextView
                                    android:id="@+id/tvTotalOrders"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    tools:text="—"
                                    style="@style/TextAppearance.Saive.Header"
                                    android:textSize="18sp"
                                    android:textColor="@color/white"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <LinearLayout
                android:baselineAligned="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:layout_marginBottom="12dp"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="?attr/colorSurface"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/colorLinen">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/admin_stats_products"
                                    style="@style/TextAppearance.Saive.Caption"
                                    android:textColor="@color/colorSand"
                                    android:textSize="11sp" />
                                <TextView
                                    android:id="@+id/tvTotalProducts"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    tools:text="—"
                                    style="@style/TextAppearance.Saive.Header"
                                    android:textSize="18sp"
                                    android:textColor="@color/colorNoirBlack"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:layout_marginBottom="12dp"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="?attr/colorSurface"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/colorLinen">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/admin_stats_users"
                                    style="@style/TextAppearance.Saive.Caption"
                                    android:textColor="@color/colorSand"
                                    android:textSize="11sp" />
                                <TextView
                                    android:id="@+id/tvTotalUsers"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    tools:text="—"
                                    style="@style/TextAppearance.Saive.Header"
                                    android:textSize="18sp"
                                    android:textColor="@color/colorNoirBlack"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <LinearLayout
                android:baselineAligned="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:layout_marginBottom="12dp"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="?attr/colorSurface"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/colorLinen">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/admin_stats_blogs"
                                    style="@style/TextAppearance.Saive.Caption"
                                    android:textColor="@color/colorSand"
                                    android:textSize="11sp" />
                                <TextView
                                    android:id="@+id/tvTotalBlogs"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    tools:text="—"
                                    style="@style/TextAppearance.Saive.Header"
                                    android:textSize="18sp"
                                    android:textColor="@color/colorNoirBlack"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:layout_marginBottom="12dp"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="?attr/colorSurface"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/colorLinen">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/admin_stats_reviews"
                                    style="@style/TextAppearance.Saive.Caption"
                                    android:textColor="@color/colorSand"
                                    android:textSize="11sp" />
                                <TextView
                                    android:id="@+id/tvTotalReviews"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    tools:text="—"
                                    style="@style/TextAppearance.Saive.Header"
                                    android:textSize="18sp"
                                    android:textColor="@color/colorNoirBlack"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>

                <!-- Analytics Chart Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_growth"
                    style="@style/TextAppearance.Saive.Caption"
                    android:textColor="@color/colorSand"
                    android:layout_marginTop="40dp"
                    android:layout_marginBottom="16dp"
                    android:letterSpacing="0.2"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/colorLinen">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="24dp">

                        <LinearLayout
                android:baselineAligned="false"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:layout_marginBottom="32dp">
                            <View android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:layout_marginHorizontal="6dp" android:background="@color/colorLinen" android:alpha="0.5"/>
                            <View android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1" android:layout_marginHorizontal="6dp" android:background="@color/colorLinen" android:alpha="0.5"/>
                            <View android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1" android:layout_marginHorizontal="6dp" android:background="@color/colorLinen" android:alpha="0.5"/>
                            <View android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_marginHorizontal="6dp" android:background="@color/colorAccentBrand"/>
                            <View android:layout_width="0dp" android:layout_height="100dp" android:layout_weight="1" android:layout_marginHorizontal="6dp" android:background="@color/colorNoirBlack"/>
                            <View android:layout_width="0dp" android:layout_height="140dp" android:layout_weight="1" android:layout_marginHorizontal="6dp" android:background="@color/colorAccentBrand" android:alpha="0.7"/>
                            <View android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:layout_marginHorizontal="6dp" android:background="@color/colorLinen" android:alpha="0.5"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            tools:text="M   T   W   T   F   S   S"
                            style="@style/TextAppearance.Saive.Caption"
                            android:textSize="@dimen/text_size_caption"
                            android:layout_centerHorizontal="true"
                            android:textColor="@color/colorSand"/>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Activity List -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_recent_activity"
                    style="@style/TextAppearance.Saive.Caption"
                    android:textColor="@color/colorSand"
                    android:layout_marginTop="40dp"
                    android:layout_marginBottom="16dp"
                    android:letterSpacing="0.2"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/colorLinen">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">
                            <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/bg_circle_maroon"/>
                            <TextView
                                android:id="@+id/tvOrderActivity"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="@dimen/spacing_medium"
                                tools:text="Order #1204 - Paid via Momo"
                                style="@style/TextAppearance.Saive.Light"
                                android:textSize="@dimen/text_size_13"
                                android:textColor="@color/colorNoirBlack"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="Just now"
                                android:textSize="@dimen/text_size_caption"
                                android:textColor="@color/colorSand"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_marginHorizontal="16dp" android:background="@color/colorLinen" android:alpha="0.5"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">
                            <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/bg_circle_black"/>
                            <TextView
                                android:id="@+id/tvInventoryAlert"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="@dimen/spacing_medium"
                                tools:text="Inventory Alert: Silk Blazer (Low)"
                                style="@style/TextAppearance.Saive.Light"
                                android:textSize="@dimen/text_size_13"
                                android:textColor="@color/colorNoirBlack"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="2h ago"
                                android:textSize="@dimen/text_size_caption"
                                android:textColor="@color/colorSand"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Drawer Menu Styled -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:background="@color/colorCotton"
        app:itemIconTint="@color/colorAccentBrand"
        app:itemTextColor="@color/colorNoirBlack"
        app:itemShapeAppearanceOverlay="@style/ShapeAppearance.Saive.Small"
        app:itemShapeInsetStart="12dp"
        app:itemShapeInsetEnd="12dp"
        app:headerLayout="@layout/admin_nav_header"
        app:menu="@menu/menu_admin_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>