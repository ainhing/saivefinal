<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorCotton"
    tools:context=".admin.activities.OrderManagementActivity"
    tools:ignore="Overdraw">

    <!-- Header / Toolbar -->
    <LinearLayout
                android:baselineAligned="false"
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="54dp"
        android:paddingBottom="20dp"
        android:gravity="center_vertical"
        android:background="@color/colorCotton"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_white"
            android:backgroundTint="@color/white"
            android:elevation="4dp"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_back"
            app:tint="@color/colorMaroon"
            android:contentDescription="@string/nav_back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="24dp"
            android:text="@string/admin_order_mgmt"
            style="@style/TextAppearance.Saive.SectionHeader"
            android:textSize="20sp"
            android:textColor="@color/colorNoirBlack"
            android:fontFamily="serif"
            android:textStyle="italic"
            android:textAllCaps="true"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <!-- Search Bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/searchCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
                android:baselineAligned="false"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/colorSand"
                android:contentDescription="@null" />

            <EditText
                android:id="@+id/etSearchOrders"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="@string/admin_search_order_hint"
                android:textSize="14sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="text"
                android:maxLines="1"
                android:importantForAutofill="no"
                android:textColor="@color/colorNoirBlack"
                android:fontFamily="sans-serif-light" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Order Tabs -->
    <HorizontalScrollView
        android:id="@+id/orderTabsScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:scrollbars="none"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/searchCard">

        <LinearLayout
                android:baselineAligned="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp">

            <TextView
                android:id="@+id/tabAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/admin_tab_all"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_rounded_black_12dp"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tabPending"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/admin_tab_pending"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_rounded_white_8dp"
                android:textColor="@color/colorNoirBlack"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"
                android:fontFamily="sans-serif-light"/>

            <TextView
                android:id="@+id/tabConfirmed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/admin_tab_confirmed"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_rounded_white_8dp"
                android:textColor="@color/colorNoirBlack"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"
                android:fontFamily="sans-serif-light"/>

            <TextView
                android:id="@+id/tabShipping"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/admin_tab_shipping"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_rounded_white_8dp"
                android:textColor="@color/colorNoirBlack"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"
                android:fontFamily="sans-serif-light"/>

            <TextView
                android:id="@+id/tabDelivered"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/admin_tab_delivered"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_rounded_white_8dp"
                android:textColor="@color/colorNoirBlack"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"
                android:fontFamily="sans-serif-light"/>

            <TextView
                android:id="@+id/tabCancelled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/admin_tab_cancelled"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_rounded_white_8dp"
                android:textColor="@color/colorNoirBlack"
                android:textSize="12sp"
                android:fontFamily="sans-serif-light"/>
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:paddingHorizontal="24dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/orderTabsScroll"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>