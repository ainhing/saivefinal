<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    app:strokeColor="@color/colorLinen"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Avatar/Profile Icon -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivEmployeeIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_profile"
            android:scaleType="centerCrop"
            android:background="@color/colorCotton"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Saive.Circle"
            app:tint="@color/colorMaroon"
            android:padding="8dp" />

        <!-- Info details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/tvEmployeeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Employee Name"
                android:textColor="@color/colorNoirBlack"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvDepartmentPosition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Department - Position"
                android:textColor="@color/colorGrayText"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvEmployeePhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="0123456789"
                android:textColor="@color/colorGrayText"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Toggle Switch -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchActive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:useMaterialThemeColors="true" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
