<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="1dp"
    app:strokeColor="@color/colorLinen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/dialogIcon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/saive_logo"
            app:tint="@color/colorMaroon"
            android:layout_marginBottom="16dp"
            android:contentDescription="@null"/>

        <TextView
            android:id="@+id/dialogTitle"
            style="@style/TextAppearance.Saive.SectionHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/alert_title_default"
            android:textColor="@color/colorMaroon"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:id="@+id/dialogMessage"
            style="@style/TextAppearance.Saive.Light"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            tools:text="This is an alert message to inform the user."
            android:textColor="@color/colorNoirBlack"
            android:textSize="15sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"/>

        <LinearLayout
                android:baselineAligned="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnNegative"
                style="@style/TextAppearance.Saive.Nav"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_rounded_linen_btn"
                android:text="@string/btn_cancel"
                android:textColor="@color/colorTextSecondary"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                android:stateListAnimator="@null" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPositive"
                style="@style/TextAppearance.Saive.Nav"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_rounded_maroon_btn"
                android:text="@string/btn_confirm"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:stateListAnimator="@null" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>