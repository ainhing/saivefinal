<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:background="@color/white">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvTermsTitle"
                style="@style/TextAppearance.Saive.SectionHeader"
                android:layout_width="match_parent"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/btnCloseTerms"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="@string/terms_title"
                android:textColor="@color/colorMaroon"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

            <ImageButton
                android:id="@+id/btnCloseTerms"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/btn_close"
                android:src="@drawable/ic_close_white"
                app:tint="@color/colorGrayText" />
        </RelativeLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:scrollbarStyle="outsideOverlay"
            android:scrollbars="vertical">

            <TextView
                android:id="@+id/tvTermsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingMultiplier="1.4"
                android:text="@string/terms_content"
                android:textColor="@color/colorNoirBlack"
                android:textSize="15sp"
                android:letterSpacing="0.01" />
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAcceptTerms"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="@string/dialog_cancel"
            android:visibility="gone"
            app:cornerRadius="28dp"
            app:backgroundTint="@color/colorMaroon" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>