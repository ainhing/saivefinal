<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_medium"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/colorAddressCardBg"
    app:cardCornerRadius="@dimen/corner_radius_large"
    app:cardElevation="0dp"
    app:strokeColor="@color/colorLinen"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_large">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvAddressLabel"
                style="@style/TextAppearance.Saive.Nav"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="@color/colorMaroon"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:id="@+id/tvDefaultBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_rounded_maroon"
                android:backgroundTint="@color/colorCotton"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="@string/address_default_label"
                android:textColor="@color/colorMaroon"
                android:textSize="11sp"
                android:visibility="visible"
                app:layout_constraintStart_toEndOf="@id/tvAddressLabel"
                app:layout_constraintTop_toTopOf="@id/tvAddressLabel"
                app:layout_constraintBottom_toBottomOf="@id/tvAddressLabel" />

            <ImageView
                android:id="@+id/btnEditAddress"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_circle_trans"
                android:padding="7dp"
                android:src="@android:drawable/ic_menu_edit"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:tint="@color/colorSand"
                android:contentDescription="@null"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tvReceiverName"
            style="@style/TextAppearance.Saive.Light"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Thao Nhi Huynh"
            android:textColor="@color/colorAddressCardText"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPhoneNumber"
            style="@style/TextAppearance.Saive.Thin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="+84 901 234 567"
            android:textColor="@color/colorAddressCardPhone"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvFullAddress"
            style="@style/TextAppearance.Saive.Light"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="123 Le Loi Street, Ben Nghe Ward, District 1, Ho Chi Minh City"
            android:textColor="@color/colorAddressCardText"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginVertical="20dp"
            android:background="@color/colorLinen" />

        <LinearLayout
                tools:ignore="UseCompoundDrawables"
                android:baselineAligned="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/cbSetDefault"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/colorMaroon"
                android:text="@string/address_set_default"
                android:textColor="@color/colorSand"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/btnDeleteAddress"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_delete_circle"
                android:padding="7dp"
                android:src="@drawable/ic_trash"
                android:contentDescription="@null"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
