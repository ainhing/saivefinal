<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
                android:baselineAligned="false" xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="24dp"
    android:paddingVertical="16dp"
    tools:ignore="Overdraw">

    <TextView
        android:id="@+id/tvOptionName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        style="@style/TextAppearance.Saive.Light"
        android:textColor="@color/colorNoirBlack"
        android:textSize="15sp"
        tools:text="Option Name" />

    <View
        android:id="@+id/viewSelectedIndicator"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_circle_white"
        android:backgroundTint="@color/colorMaroon"
        android:visibility="gone" />

</LinearLayout>