<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardAddress"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/colorAddressCardBg"
    app:strokeWidth="1dp"
    app:strokeColor="@color/colorLightGray">

    <LinearLayout
                android:baselineAligned="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvLabel"
                style="@style/TextAppearance.Saive.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorMaroon"/>

            <TextView
                android:id="@+id/tvFullName"
                style="@style/TextAppearance.Saive.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thao Nhi Huynh"
                android:layout_marginTop="4dp"
                android:textColor="@color/colorAddressCardText"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/tvAddressDetail"
                style="@style/TextAppearance.Saive.SubLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="123 Le Loi Street, District 1, HCM"
                android:layout_marginTop="2dp"
                android:textColor="@color/colorAddressCardText"
                android:alpha="0.7"/>

            <TextView
                android:id="@+id/tvPhone"
                style="@style/TextAppearance.Saive.SubLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+84 901 234 567"
                android:layout_marginTop="2dp"
                android:textColor="@color/colorAddressCardPhone"
                android:textSize="12sp"
                android:alpha="0.8"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/ivCheck"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_check_circle"
            app:tint="@color/colorMaroon"
            android:visibility="gone"
            android:contentDescription="@null"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>