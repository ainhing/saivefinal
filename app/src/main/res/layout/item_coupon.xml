<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="NestedWeights"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
                android:baselineAligned="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Left side: Discount Area -->
        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="match_parent"
            android:background="@color/colorMaroon"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDiscountValue"
                    style="@style/TextAppearance.Saive.Thin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20%"
                    android:textColor="@color/colorOnMaroon"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    style="@style/TextAppearance.Saive.Nav"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/coupon_off"
                    android:textColor="@color/colorOnMaroon"
                    android:textSize="12sp"
                    android:letterSpacing="0.05"
                    android:gravity="center" />
            </LinearLayout>

        </FrameLayout>

        <!-- Vertical Dash Divider -->
        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:background="@drawable/dash_line_vertical"
            android:layerType="software" />

        <!-- Right side: Details -->
        <LinearLayout
                android:baselineAligned="false"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/colorIvory"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCouponTitle"
                    style="@style/TextAppearance.Saive.Header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SAIVE WELCOME"
                    android:textColor="@color/colorNoirBlack"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCouponDesc"
                    style="@style/TextAppearance.Saive.Thin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="On your first archive access."
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvExpiry"
                    style="@style/TextAppearance.Saive.Nav"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Valid until: Dec 31, 2024"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnApply"
                style="@style/TextAppearance.Saive.Nav"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_cart_variant"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="@string/coupon_copy"
                android:textColor="@color/colorNoirBlack"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
