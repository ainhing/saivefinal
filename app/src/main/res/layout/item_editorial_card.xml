<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="24dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivEditorial"
        android:layout_width="140dp"
        android:layout_height="190dp"
        android:layout_marginStart="16dp"
        android:scaleType="centerCrop"
        tools:src="@drawable/model1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/RoundedAppearance" />

    <TextView
        android:id="@+id/tvCardTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.1"
        android:text="@string/editorial_title_3"
        android:textColor="@color/colorNoirBlack"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/ivEditorial"
        app:layout_constraintTop_toTopOf="@id/ivEditorial" />

    <TextView
        android:id="@+id/tvCardStory"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif-light"
        android:lineSpacingExtra="6dp"
        android:maxLines="6"
        android:text="@string/editorial_story_3"
        android:textColor="@color/colorTextSecondary"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvCardTitle"
        app:layout_constraintTop_toBottomOf="@id/tvCardTitle" />

    <TextView
        android:id="@+id/tvCardMaterial"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:alpha="0.4"
        android:fontFamily="sans-serif-thin"
        android:text="@string/editorial_material_3"
        android:textColor="@color/colorNoirBlack"
        android:textSize="11sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@id/tvCardTitle"
        app:layout_constraintStart_toStartOf="@id/tvCardTitle"
        app:layout_constraintTop_toBottomOf="@id/tvCardStory" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCTA"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-medium"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:letterSpacing="0.08"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:text="@string/btn_explore"
        android:textColor="@color/colorMaroon"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="@id/tvCardTitle"
        app:layout_constraintTop_toBottomOf="@id/tvCardStory" />

    <View
        android:layout_width="32dp"
        android:layout_height="1dp"
        android:layout_marginTop="4dp"
        android:background="@color/colorMaroon"
        android:alpha="0.6"
        app:layout_constraintStart_toStartOf="@id/btnCTA"
        app:layout_constraintTop_toBottomOf="@id/btnCTA" />

</androidx.constraintlayout.widget.ConstraintLayout>