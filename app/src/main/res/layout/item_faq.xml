<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/colorCotton"
    android:foreground="?attr/selectableItemBackground"
    android:paddingVertical="20dp"
    tools:ignore="Overdraw">

    <TextView
        android:id="@+id/tvQuestion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        tools:text="Question here"
        android:textSize="15sp"
        android:fontFamily="serif"
        android:textStyle="bold"
        android:textColor="@color/colorNoirBlack"
        android:letterSpacing="0.02"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/ivChevron"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivChevron"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_chevron_down"
        app:tint="@color/colorAccentBrand"
        android:layout_marginStart="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvQuestion"
        app:layout_constraintBottom_toBottomOf="@id/tvQuestion"
        android:contentDescription="@null"/>

    <TextView
        android:id="@+id/tvAnswer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        tools:text="Answer here"
        android:textSize="14sp"
        android:fontFamily="sans-serif-light"
        android:textColor="@color/colorGrayText"
        android:lineSpacingExtra="6dp"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvQuestion" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorLinen"
        android:alpha="0.3"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvAnswer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>