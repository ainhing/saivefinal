<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/colorMaroon">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:padding="24dp">

        <ImageView
            android:id="@+id/ivCardChip"
            android:layout_width="48dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="@color/colorSand"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:contentDescription="@null"/>

        <TextView
            android:id="@+id/tvCardType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VISA"
            style="@style/TextAppearance.Saive.Header"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold|italic"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvCardNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="**** **** **** 4242"
            style="@style/TextAppearance.Saive.Header"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:letterSpacing="0.1"
            app:layout_constraintTop_toBottomOf="@id/ivCardChip"
            app:layout_constraintBottom_toTopOf="@id/tvCardHolder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvCardHolderLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_card_holder_caps"
            style="@style/TextAppearance.Saive.Caption"
            android:textColor="@color/colorOnMaroonSecondary"
            android:textSize="12sp"
            app:layout_constraintBottom_toTopOf="@id/tvCardHolder"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvCardHolder"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="HUYNH THAO NHI"
            style="@style/TextAppearance.Saive.Nav"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textAllCaps="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvExpiryDate" />

        <TextView
            android:id="@+id/tvExpiryLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_expires_caps"
            style="@style/TextAppearance.Saive.Caption"
            android:textColor="@color/colorOnMaroonSecondary"
            android:textSize="12sp"
            app:layout_constraintBottom_toTopOf="@id/tvExpiryDate"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvExpiryDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12/26"
            style="@style/TextAppearance.Saive.Nav"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
