<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="24dp">

    <LinearLayout
                android:baselineAligned="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvReviewUser"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/TextAppearance.Saive.Label"
            android:text="@string/mock_user_name"
            android:textColor="@color/colorNoirBlack"
            android:textSize="13sp"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/tvReviewDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Saive.Nav"
            android:text="@string/mock_review_date"
            android:alpha="0.4"
            android:textSize="11sp" />
    </LinearLayout>

    <RatingBar
        android:id="@+id/ratingBar"
        style="@android:style/Widget.DeviceDefault.RatingBar.Small"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:numStars="5"
        android:rating="5"
        android:progressTint="@color/colorMaroon"
        android:secondaryProgressTint="@color/colorMaroon" />

    <TextView
        android:id="@+id/tvReviewComment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        style="@style/TextAppearance.Saive.Light"
        android:lineSpacingExtra="4dp"
        android:text="@string/mock_review_comment"
        android:textColor="@color/colorNoirBlack"
        android:textSize="15sp"
        android:alpha="0.9" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvReviewImages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="24dp"
        android:background="@color/colorNoirBlack"
        android:alpha="0.05" />

</LinearLayout>

