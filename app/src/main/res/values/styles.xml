<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Quiet Luxury Typography Styles -->
    <!-- Font Sans-Serif cho nội dung chính -->
    <style name="TextAppearance.Saive.Thin" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="TextAppearance.Saive.Light" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="TextAppearance.Saive.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textColor">@color/colorNoirBlack</item>
    </style>

    <!-- Font Serif cho Header (Sử dụng serif làm fallback, hãy thêm Bodoni Moda vào res/font) -->
    <style name="TextAppearance.Saive.Header" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:fontFamily">serif</item>
        <item name="android:textStyle">italic</item>
        <item name="android:textSize">@dimen/text_size_h1</item>
        <item name="android:textColor">@color/colorNoirBlack</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.Saive.SectionHeader" parent="TextAppearance.Saive.Header">
        <item name="android:textSize">@dimen/text_size_h3</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Font Sans-Serif cho Nhãn (Giống hình mẫu: Flash Sale) -->
    <style name="TextAppearance.Saive.Label" parent="TextAppearance.Saive.Thin">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/text_size_tiny</item>
        <item name="android:textColor">@color/colorNoirBlack</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="TextAppearance.Saive.SubLabel" parent="TextAppearance.Saive.Light">
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textColor">@color/colorGrayText</item>
    </style>

    <style name="TextAppearance.Saive.Nav" parent="TextAppearance.Saive.Light">
        <item name="android:textSize">@dimen/text_size_tiny</item>
        <item name="android:letterSpacing">0.06</item>
    </style>

    <style name="TextAppearance.Saive.Caption" parent="TextAppearance.Saive.Thin">
        <item name="android:textSize">@dimen/text_size_tiny</item>
        <item name="android:letterSpacing">0.06</item>
    </style>

    <style name="TextAppearance.Saive.Editorial" parent="TextAppearance.Saive.Header">
        <item name="android:textSize">18sp</item>
        <item name="android:lineSpacingExtra">8dp</item>
    </style>

    <style name="TextAppearance.Saive.Logo" parent="TextAppearance.Saive.Thin">
        <item name="android:textSize">@dimen/logo_text_size</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:letterSpacing">-0.05</item>
        <item name="android:textColor">@color/colorMaroon</item>
    </style>

    <style name="TextAppearance.Saive.Logo.Huge">
        <item name="android:textSize">@dimen/logo_text_size_huge</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:letterSpacing">-0.08</item>
        <item name="android:textColor">@color/colorMaroon</item>
    </style>

    <style name="TextAppearance.Saive.Stats.Number" parent="TextAppearance.Saive.Header">
        <item name="android:textSize">@dimen/text_size_h1</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/colorNoirBlack</item>
    </style>

    <style name="TextAppearance.Saive.Stats.Label" parent="TextAppearance.Saive.Label">
        <item name="android:textSize">@dimen/text_size_tiny</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
    </style>

    <style name="TextAppearance.Saive.ProductTitle" parent="TextAppearance.Saive.Header">
        <item name="android:fontFamily">serif</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="RoundedAppearance" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.Saive.Small" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.Saive.Square" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.Saive.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShapeAppearance.Saive.ProductImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="DatePickerTheme" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="colorPrimary">@color/colorMaroon</item>
        <item name="colorAccent">@color/colorMaroon</item>
    </style>

    <style name="OtpBoxStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">@drawable/bg_rounded_white_8dp</item>
        <item name="android:backgroundTint">@color/colorCotton</item>
        <item name="android:gravity">center</item>
        <item name="android:inputType">number</item>
        <item name="android:maxLength">1</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/colorMaroon</item>
        <item name="android:textStyle">bold</item>
        <item name="android:cursorVisible">false</item>
        <item name="android:hint">@string/otp_hint</item>
    </style>

    <style name="RatingBar" parent="Theme.AppCompat">
        <item name="colorControlNormal">@color/colorSand</item>
        <item name="colorControlActivated">@color/colorMaroon</item>
    </style>

</resources>