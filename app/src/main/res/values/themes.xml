<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.Saive" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowSharedElementEnterTransition">@android:transition/move</item>
        <item name="android:windowSharedElementExitTransition">@android:transition/move</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/colorCotton</item>

        <!-- Material 3 Color Palette Overrides to remove default Purple -->
        <item name="colorPrimary">@color/colorMaroon</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/colorMaroon</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="colorSecondaryContainer">@color/colorLinen</item>
        <item name="colorOnSecondaryContainer">@color/colorNoirBlack</item>
        <item name="colorTertiary">@color/colorNoirBlack</item>
        <item name="android:colorBackground">@color/colorCotton</item>
        <item name="colorSurface">@color/colorCotton</item>
        <item name="colorOnSurface">@color/colorNoirBlack</item>

        <!-- Global Font Settings -->
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Saive.Header</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Saive.Header</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Saive.SectionHeader</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Saive.Thin</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Saive.Light</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.Saive.Label</item>
    </style>

    <style name="Theme.Saive" parent="Base.Theme.Saive" />

    <style name="SaiveDialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="BottomSheetDialogTheme" parent="Theme.Material3.DayNight.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/colorCotton</item>
    </style>

    <style name="TransparentBottomSheetDialog" parent="Theme.Material3.DayNight.BottomSheetDialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">false</item>
    </style>

    <style name="CustomBottomSheetStyle" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearanceOverlay">@style/BottomSheetShapeAppearance</item>
        <item name="backgroundTint">@color/colorCotton</item>
    </style>

    <style name="BottomSheetShapeAppearance" parent="">
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/colorCotton</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/saive_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.Saive</item>
    </style>
</resources>